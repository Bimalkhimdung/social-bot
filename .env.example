# =============================================================================
# NEPSE Facebook Auto-Poster Bot — Environment Variables
# Copy this to .env and fill in your values. Never commit .env to source control.
# =============================================================================

# --- Database ---
# SQLite (default dev): leave as-is
# PostgreSQL (prod): postgresql+asyncpg://user:pass@host:5432/nepsebot
DATABASE_URL=sqlite+aiosqlite:///./nepsebot.db

# --- Auth ---
# Admin password for the dashboard. Change this!
ADMIN_PASSWORD=changeme123
# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=supersecretjwtsecret
JWT_EXPIRE_MINUTES=1440

# --- Facebook / Meta Graph API ---
# Long-lived Page Access Token (from Meta Developer Portal)
FB_PAGE_ACCESS_TOKEN=
# Facebook Page ID (numeric)
FB_PAGE_ID=

# --- Scheduler ---
# Scrape interval in minutes (default: 30)
SCRAPE_INTERVAL_MINUTES=30
# Max posts per day (default: 4)
MAX_POSTS_PER_DAY=4
# Quiet hours: no posts published between these hours (24h, local time)
QUIET_HOURS_START=22
QUIET_HOURS_END=6
# Auto-approve scraped articles for posting without human review
AUTO_APPROVE=false

# --- Caption Template ---
# Available placeholders: {title} {source} {date} {hashtags} {url}
CAPTION_TEMPLATE=📰 {title}\n\n🔗 {source} | {date}\n\n{hashtags}

# --- Default Hashtags ---
DEFAULT_HASHTAGS=#NEPSE #ShareMarket #Nepal #StockMarket #लगानी #सेयर

# --- CORS ---
# Frontend URL (update if deploying separately)
FRONTEND_URL=http://localhost:5173

# --- Scraper Keywords ---
# Set to false to disable keyword filtering and scrape everything
ENABLE_KEYWORD_FILTER=true

# --- API URLs (Frontend Proxy) ---
# Used natively by Vite's proxy and frontend applications connecting to the backend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# --- Log Level ---
LOG_LEVEL=INFO
