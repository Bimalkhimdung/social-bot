# =============================================================================
# NEPSE Bot Backend — Environment Variables
# Copy this to .env and fill in your values.
# =============================================================================

# --- Database ---
# SQLite (dev): sqlite+aiosqlite:///./nepsebot.db
# PostgreSQL (prod): postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/nepsebot

# --- Auth ---
ADMIN_PASSWORD=password
JWT_SECRET=supersecretjwtsecret
JWT_EXPIRE_MINUTES=1440

# --- Facebook / Meta Graph API ---
FB_PAGE_ACCESS_TOKEN=
FB_PAGE_ID=

# --- Scheduler ---
SCRAPE_INTERVAL_MINUTES=30
MAX_POSTS_PER_DAY=4
QUIET_HOURS_START=22
QUIET_HOURS_END=6
AUTO_APPROVE=false

# --- Caption Template ---
# Available placeholders: {title} {source} {date} {hashtags} {url}
CAPTION_TEMPLATE=📰 {title}\n\n🔗 {source} | {date}\n\n{hashtags}
DEFAULT_HASHTAGS=#NEPSE #ShareMarket #Nepal #StockMarket #लगानी #सेयर

# --- CORS ---
# Frontend URL for backend to allow requests
FRONTEND_URL=http://localhost:5173

# --- Scraper Keywords ---
ENABLE_KEYWORD_FILTER=false

# --- Log Level ---
LOG_LEVEL=INFO
