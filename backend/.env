# =============================================================================
# NEPSE Bot — Environment (backend/.env)
# =============================================================================

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://bimalrai:bimalrai@localhost:5432/nepsebot

# --- Auth ---
ADMIN_PASSWORD=password
JWT_SECRET=supersecretjwtsecret
JWT_EXPIRE_MINUTES=1440

# --- Facebook / Meta Graph API ---
FB_PAGE_ACCESS_TOKEN=
FB_PAGE_ID=

# --- Scheduler ---
SCRAPE_INTERVAL_MINUTES=30
MAX_POSTS_PER_DAY=4
QUIET_HOURS_START=22
QUIET_HOURS_END=6
AUTO_APPROVE=false

# --- Caption ---
CAPTION_TEMPLATE=📰 {title}\n\n🔗 {source} | {date}\n\n{hashtags}
DEFAULT_HASHTAGS=#NEPSE #ShareMarket #Nepal #StockMarket #लगानी #सेयर

# --- CORS ---
FRONTEND_URL=http://localhost:5173

# --- Logging ---
LOG_LEVEL=INFO
